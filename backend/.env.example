# Database
DB_HOST=localhost
DB_PORT=5433
DB_NAME=freesign
DB_USER=freesign
DB_PASSWORD=your_password_here

# JWT Secret
JWT_SECRET=generate_a_random_secret

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_PRO_PRICE_ID=price_auto_created
STRIPE_BUSINESS_PRICE_ID=price_auto_created

# Email (optional - logs verification links if not set)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_user
# SMTP_PASS=your_pass
# FROM_EMAIL=noreply@freesign.ink

# Or use SendGrid:
# SENDGRID_API_KEY=SG.your_key

# Application
PORT=3100
NODE_ENV=production
FRONTEND_URL=https://freesign.ink
CORS_ORIGIN=https://freesign.ink
